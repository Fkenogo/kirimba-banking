rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Member can read own profile. Writes are backend-only via Cloud Functions/Admin SDK.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Member can read own wallet. Writes are backend-only via Cloud Functions/Admin SDK.
    match /wallets/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Default deny for all other collections until explicit rules are added.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
