rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : "";
    }

    function isSuperAdmin() {
      return role() == "super_admin";
    }

    function isAdmin() {
      return role() == "super_admin" || role() == "admin" || role() == "finance";
    }

    function isAgent() {
      return role() == "agent";
    }

    function isInstitutionUser() {
      return role() == "institution_user";
    }

    function isLeader() {
      return role() == "leader";
    }

    function isMember() {
      return role() == "member";
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Profiles: members read own profile; elevated roles can read all.
    // isInstitutionUser() included so institution staff can resolve agent/member names in batch detail.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isAgent() || isInstitutionUser();
      allow write: if false;
    }

    // Wallets: members read own wallet; elevated roles can read all.
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isAgent();
      allow write: if false;
    }

    // Groups: readable only by members of that group or elevated roles.
    // borrowingPaused / pauseReason / pausedAt / pausedBy are managed by
    // the adminSetGroupBorrowPause callable (Admin SDK, bypasses rules).
    // isAdmin() read access below covers those fields for admin UI queries.
    match /groups/{groupId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isAgent() ||
        isInstitutionUser() ||
        // The documented group leader can always read their group regardless of token-claim state.
        resource.data.leaderId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/groupMembers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/groupMembers/$(request.auth.uid)).data.groupId == groupId
        )
      );
      allow write: if false;

      match /joinRequests/{joinRequestId} {
        allow read: if isSignedIn() && (isAdmin() || isLeader());
        allow write: if false;
      }
    }

    match /groupMembers/{memberId} {
      allow read: if isSignedIn() && (isOwner(memberId) || isAdmin() || isAgent() || isLeader());
      allow write: if false;
    }

    match /transactions/{txnId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isAgent() ||
        isInstitutionUser() ||
        resource.data.userId == request.auth.uid
      );
      allow write: if false;
    }

    match /loans/{loanId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isAgent() ||
        isInstitutionUser() ||
        resource.data.userId == request.auth.uid
      );
      allow write: if false;
    }

    match /depositBatches/{batchId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isAgent() ||
        // institution_user: scoped to own institution only
        (isInstitutionUser() && resource.data.institutionId == request.auth.token.institutionId)
      );
      allow write: if false;
    }

    match /kirimbaFund/{recordId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /fundLedger/{entryId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /fundMovements/{movementId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /withdrawalRequests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || isAgent() || resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.recipientId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow write: if false;
    }

    match /agents/{agentId} {
      allow read: if isAdmin() || isOwner(agentId) || isAgent();
      allow write: if false;
    }

    match /agentLedgers/{ledgerId} {
      allow read: if isAdmin() || (isAgent() && resource.data.agentId == request.auth.uid);
      allow write: if false;
    }

    match /config/{configId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /systemConfig/{configId} {
      allow read: if isAdmin();
      allow write: if false; // super_admin writes via Cloud Function (audit-logged)
    }

    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false; // backend only
    }

    match /agentReconciliations/{reconcId} {
      allow read: if isAdmin() || (isAgent() && resource.data.agentId == request.auth.uid);
      allow write: if false;
    }

    match /agentSettlements/{settlementId} {
      allow read: if isAdmin() || (isAgent() && resource.data.agentId == request.auth.uid);
      allow write: if false;
    }

    match /institutions/{institutionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /kirimbaPools/{poolId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /institutionPools/{institutionId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (isInstitutionUser() && institutionId == request.auth.token.institutionId)
      );
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
