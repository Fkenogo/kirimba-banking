{
  "name": "kirimba-banking",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "functions",
    "apps/*"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:member": "npm --workspace apps/member run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "dev:agent": "npm --workspace apps/agent run dev -- --host 127.0.0.1 --port 5174 --strictPort",
    "dev:admin": "npm --workspace apps/admin run dev -- --host 127.0.0.1 --port 5175 --strictPort",
    "dev:umuco": "npm --workspace apps/umuco run dev -- --host 127.0.0.1 --port 5176 --strictPort",
    "dev:all": "concurrently -n MEMBER,AGENT,ADMIN,UMUCO -c green,blue,magenta,cyan \"npm run dev:member\" \"npm run dev:agent\" \"npm run dev:admin\" \"npm run dev:umuco\"",
    "preview:member": "npm --workspace apps/member run preview -- --host 127.0.0.1 --port 4173 --strictPort",
    "preview:agent": "npm --workspace apps/agent run preview -- --host 127.0.0.1 --port 4174 --strictPort",
    "preview:admin": "npm --workspace apps/admin run preview -- --host 127.0.0.1 --port 4175 --strictPort",
    "preview:umuco": "npm --workspace apps/umuco run preview -- --host 127.0.0.1 --port 4176 --strictPort",
    "preview:all": "concurrently -n MEMBER,AGENT,ADMIN,UMUCO -c green,blue,magenta,cyan \"npm run preview:member\" \"npm run preview:agent\" \"npm run preview:admin\" \"npm run preview:umuco\"",
    "build:member": "npm --workspace apps/member run build",
    "build:agent": "npm --workspace apps/agent run build",
    "build:admin": "npm --workspace apps/admin run build",
    "build:umuco": "npm --workspace apps/umuco run build",
    "build:functions": "npm --workspace functions run deploy -- --only functions",
    "build:all": "npm run build:member && npm run build:agent && npm run build:admin && npm run build:umuco",
    "seed:test-env": "node scripts/seed-kirimba-test-env.js",
    "seed:test-env:reset": "node scripts/seed-kirimba-test-env.js --reset",
    "validate:lending-economics": "GCLOUD_PROJECT=kirimba-banking FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/validate-lending-economics.mjs",
    "seed:risk-qa": "node scripts/seed-risk-exceptions-qa.js",
    "seed:risk-qa:reset": "node scripts/seed-risk-exceptions-qa.js --reset",
    "capture:users-roles": "node --experimental-websocket scripts/capture-users-roles-module.mjs",
    "capture:user-provisioning": "node --experimental-websocket scripts/capture-user-provisioning-module.mjs",
    "capture:institutions": "node --experimental-websocket scripts/capture-institutions-module.mjs",
    "capture:agents": "node --experimental-websocket scripts/capture-agents-module.mjs",
    "capture:risk-qa": "node --experimental-websocket scripts/capture-risk-exceptions-qa.mjs",
    "emulators": "firebase emulators:start",
    "emulators:core": "firebase emulators:start --only auth,firestore,functions",
    "emulators:auth": "firebase emulators:start --only auth",
    "build:deploy": "npm run build:all && firebase deploy",
    "deploy:all": "npm run build:all && firebase deploy",
    "deploy": "npm run build:all && firebase deploy"
  },
  "dependencies": {
    "firebase": "^12.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
